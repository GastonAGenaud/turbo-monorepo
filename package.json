{
  "name": "ggseeds-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "infra:validate": "aws cloudformation validate-template --template-body file://infra/cloudformation/ggseeds-stack.yaml",
    "infra:local:up": "docker compose -f docker-compose.localstack.yml up -d",
    "infra:local:deploy": "bash scripts/localstack/deploy-cloudformation.sh",
    "infra:local:down": "docker compose -f docker-compose.localstack.yml down -v",
    "github:sync:actions": "bash scripts/github/sync-actions-config.sh",
    "aws:render:admin-env": "bash scripts/aws/render-admin-env.sh",
    "aws:render:storefront-env": "bash scripts/aws/render-storefront-env.sh",
    "vercel:sync:admin-env": "bash scripts/vercel/sync-admin-env.sh",
    "vercel:sync:storefront-env": "bash scripts/vercel/sync-storefront-env.sh",
    "docker:scraper:build": "docker build -f Dockerfile.scraper -t ggseeds-scraper:local .",
    "db:generate": "pnpm --filter @ggseeds/db db:generate",
    "db:migrate": "pnpm --filter @ggseeds/db db:migrate",
    "db:seed": "pnpm --filter @ggseeds/db db:seed",
    "import:all": "pnpm --filter @ggseeds/scrapers run import all",
    "import:merlin": "pnpm --filter @ggseeds/scrapers run import merlin",
    "import:dutch": "pnpm --filter @ggseeds/scrapers run import dutch",
    "import:images": "pnpm --filter @ggseeds/scrapers run refresh-images all",
    "import:images:merlin": "pnpm --filter @ggseeds/scrapers run refresh-images merlin",
    "import:images:dutch": "pnpm --filter @ggseeds/scrapers run refresh-images dutch"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "eslint": "9.21.0",
    "eslint-config-prettier": "10.1.1",
    "prettier": "3.5.2",
    "turbo": "2.4.4",
    "typescript": "5.8.2",
    "vitest": "3.0.8",
    "@eslint/js": "9.21.0"
  }
}
